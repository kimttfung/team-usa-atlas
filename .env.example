# Environment template for Team USA Atlas
#
# Copy this file to `.env` (which is git-ignored) and fill in your values.
# The server reads these via `dotenv` at boot.

# Google AI Studio API key. Get one at:
#   https://aistudio.google.com/apikey
# Free tier is sufficient for development.
GEMINI_API_KEY=

# Gemini model name. Defaults to flash-lite for speed + low cost.
# Other valid values include `gemini-3.1-flash` and `gemini-2.5-flash`.
GEMINI_MODEL=gemini-3.1-flash-lite

# Local server port. Keep at 8000 to match the existing dev URL.
PORT=8000
